# ============================================================
# Agents secrets and deployment overrides
#
# Non-secret defaults live in config/defaults.toml.
# Local non-secret overrides should go in config/local.toml, which is gitignored.
# Keep this file focused on tokens, credentials, and deployment-only env overrides.
# ============================================================

# API access token for the gateway; leave empty to disable token auth.
ACCESS_TOKEN=

# Model provider secrets.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Project-owned Claude-compatible override; higher priority than ANTHROPIC_*.
AGENT_CLAUDE_API_KEY=

# Tavily web search secret.
WEB_SEARCH_TAVILY_API_KEY=

# Optional deployment overrides. Prefer config/local.toml for local non-secret changes.
# ENV_FILE=.env
# AGENTS_DEFAULT_CONFIG=config/defaults.toml
# AGENTS_LOCAL_CONFIG=config/local.toml
