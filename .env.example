# ============================================================
# Agents 核心配置（未列出的项使用代码默认值）
# 完整配置项参见 gateway/core/config/
# ============================================================

# 开发模式（默认 False）
DEBUG=True

# 服务端口（默认 8010）
# PORT=8010

# API 访问令牌（留空表示不启用鉴权）
# ACCESS_TOKEN=your-secret-token

# ------------------------------------------------------------
# 模型配置（至少配置一个 API Key）
# ------------------------------------------------------------
AGENT_PROVIDER=openai-chat

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Claude provider 的备选配置（优先级高于 ANTHROPIC_*）
# AGENT_CLAUDE_API_KEY=
# AGENT_CLAUDE_MODEL=

# ------------------------------------------------------------
# 可选功能
# ------------------------------------------------------------

# MCP 工具服务器（留空表示不启用）
# MCP_SERVER_COMMAND=node ./mcp-server/build/index.js
# MCP_EXECUTION_MODE=trusted_control_plane
# MCP_SANDBOX_PROFILE=

# 引导式工具使用（留空表示不启用）
# 格式: tool_name:keyword1,keyword2;tool2:kw3
# AGENT_GUIDED_TOOLS=weather:天气,温度;search:搜索

# 默认暴露给模型的内置工具。默认只启用安全的 workspace 读工具。
# 可选: patch.apply,web.search,web.extract,web.map,browser.open,browser.download,test.run,shell.run
# AGENT_BUILTIN_TOOLS=filesystem.read,filesystem.list

# 内置 Web Search。API key 留在 control plane，不进入 sandbox。
# WEB_SEARCH_PROVIDER=none
# WEB_SEARCH_PROVIDER=tavily
# WEB_SEARCH_TAVILY_API_KEY=
# WEB_SEARCH_TAVILY_BASE_URL=https://api.tavily.com
# WEB_SEARCH_MAX_RESULTS=5
# WEB_SEARCH_MAX_CREDITS_PER_RUN=10
# WEB_SEARCH_ALLOW_ADVANCED=false
# WEB_SEARCH_ALLOW_RAW_CONTENT=false
# WEB_SEARCH_ALLOW_DOMAINS=
# WEB_SEARCH_DENY_DOMAINS=

# Sandbox 执行层。workspace 是持久化数据；sandbox 是读写/命令/测试工具的执行租约。
# Profile: restricted/coding/test/browser。默认 restricted 只读；coding/test/browser 会打开对应最小执行能力。
# AGENT_SANDBOX_PROFILE=restricted
# AGENT_SANDBOX_PROVIDER=local
# 可选 Docker 执行层: AGENT_SANDBOX_PROVIDER=docker
# AGENT_SANDBOX_IMAGE=python:3.12-slim
# AGENT_SANDBOX_NETWORK=none
# AGENT_SANDBOX_MEMORY=
# AGENT_SANDBOX_CPUS=
# AGENT_SANDBOX_TTL_SECONDS=0
# AGENT_SANDBOX_WORKDIR=/workspace

# Sandbox 策略。写文件、进程和网络默认关闭；按需显式打开。
# AGENT_SANDBOX_ALLOW_FILE_WRITE=false
# AGENT_SANDBOX_ALLOW_PROCESS=false
# AGENT_SANDBOX_ALLOW_NETWORK=false
# AGENT_SANDBOX_ALLOWED_COMMANDS=git,pytest,python3

# Agent 工作区根目录（按 user_id/agent_id 分配子目录）
# AGENT_WORKSPACE_ROOT=.agents/workspaces

# Run/checkpoint/audit 存储（memory/file/sqlite；file 仅持久化 run 记录）
# AGENT_RUN_STORE=memory
# AGENT_RUN_ROOT=.agents/runs
# AGENT_DB_PATH=.agents/agents.db

# 长上下文和记忆注入
# AGENT_MEMORY_CONTEXT_LIMIT=20
# AGENT_CONTEXT_COMPACTION_TARGET_TOKENS=32000

# 代理（如需）
# AGENT_HTTPS_PROXY=http://127.0.0.1:7890
